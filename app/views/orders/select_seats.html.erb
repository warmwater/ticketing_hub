<%# Seat Selection - Customer Pick Flow %>

<%= turbo_stream_from "event_#{@event.id}_seats" %>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to event_path(@event), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("orders.select_seats.back_to_event") %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-gray-200">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4 sm:px-8">
      <h1 class="text-xl font-bold text-gray-900"><%= t("orders.select_seats.title") %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @event.name %></p>
    </div>

    <%= form_with url: event_orders_path(@event), method: :post, data: {
          controller: "seat-picker",
          turbo_frame: "_top",
          seat_picker_event_id_value: @event.id,
          seat_picker_all_selected_text_value: t("orders.select_seats.all_selected"),
          seat_picker_select_more_text_value: t("orders.select_seats.select_more"),
          seat_picker_select_seats_hint_text_value: t("orders.select_seats.select_seats_hint"),
          seat_picker_seat_taken_notice_text_value: t("orders.select_seats.seat_taken_notice"),
          seat_picker_seat_held_notice_text_value: t("orders.select_seats.seat_held_notice")
        } do |f| %>
      <div class="p-6 sm:p-8 space-y-8">
        <!-- Legend -->
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <div class="flex items-center gap-1.5">
            <div class="h-5 w-5 rounded bg-emerald-500 ring-1 ring-emerald-600"></div>
            <span class="text-gray-600"><%= t("orders.select_seats.available") %></span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-5 w-5 rounded bg-indigo-500 ring-1 ring-indigo-600"></div>
            <span class="text-gray-600"><%= t("orders.select_seats.selected") %></span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-5 w-5 rounded bg-amber-400 ring-1 ring-amber-500"></div>
            <span class="text-gray-600"><%= t("orders.select_seats.held") %></span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-5 w-5 rounded bg-slate-400 ring-1 ring-slate-500"></div>
            <span class="text-gray-600"><%= t("orders.select_seats.taken") %></span>
          </div>
        </div>

        <% @selections.each do |sel| %>
          <div class="rounded-xl border border-gray-200 p-5" data-seat-picker-target="section"
               data-section-ticket-type-id="<%= sel[:ticket_type].id %>"
               data-section-required="<%= sel[:quantity] %>">

            <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
              <div>
                <h2 class="text-lg font-semibold text-gray-900"><%= sel[:section].name %></h2>
                <p class="text-sm text-gray-500">
                  <%= sel[:ticket_type].name %> &middot; <%= number_to_currency(sel[:ticket_type].price) %>
                </p>
              </div>
              <div class="rounded-full bg-indigo-50 px-3 py-1 ring-1 ring-indigo-200">
                <span class="text-sm font-semibold text-indigo-700">
                  <%= t("orders.select_seats.select_counter", selected: '<span data-seat-picker-target="counter" data-counter-for="' + sel[:ticket_type].id.to_s + '">0</span>', total: sel[:quantity]).html_safe %>
                </span>
              </div>
            </div>

            <!-- Seat Map -->
            <div class="overflow-x-auto">
              <div class="inline-block rounded-lg bg-gray-50 p-4 min-w-fit">
                <!-- Stage indicator -->
                <div class="mb-3 text-center">
                  <div class="inline-block rounded-t-xl bg-gray-300 px-12 py-1.5 text-xs font-semibold uppercase tracking-widest text-gray-600"><%= t("orders.select_seats.stage") %></div>
                </div>

                <% sel[:all_seats].group_by(&:row_label).each do |row_label, seats| %>
                  <div class="flex items-center gap-1 mb-1">
                    <span class="w-7 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                    <% seats.each do |seat| %>
                      <% if sel[:taken_seat_ids].include?(seat.id) %>
                        <%= render "orders/taken_seat", seat: seat %>
                      <% elsif sel[:held_seat_ids].include?(seat.id) %>
                        <%= render "orders/held_seat", seat: seat %>
                      <% else %>
                        <%= render "orders/available_seat", seat: seat, ticket_type: sel[:ticket_type] %>
                      <% end %>
                    <% end %>
                    <span class="w-7 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- GA ticket types (if any, just pass quantities through) -->
        <% @ticket_quantities.each do |ticket_type_id, quantity| %>
          <% tt = @event.ticket_types.find_by(id: ticket_type_id) %>
          <% next unless tt %>
          <% next if tt.section&.seated? %>
          <input type="hidden" name="ticket_quantities[<%= ticket_type_id %>]" value="<%= quantity %>">
        <% end %>
      </div>

      <!-- Hidden seat selection inputs (populated by Stimulus) -->
      <div data-seat-picker-target="hiddenInputs"></div>

      <!-- Submit -->
      <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 sm:px-8">
        <div class="flex items-center justify-between">
          <p class="text-sm text-gray-500" data-seat-picker-target="status"><%= t("orders.select_seats.select_seats_hint") %></p>
          <%= f.submit t("orders.select_seats.confirm_seats"),
              disabled: true,
              data: { seat_picker_target: "submitBtn" },
              class: "rounded-lg bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

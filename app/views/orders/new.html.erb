<%# New Order - Order Summary & Checkout %>

<div class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to event_path(@event), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("orders.new.back_to_event") %>
    <% end %>
  </div>

  <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("orders.new.checkout") %></h1>
  <p class="mt-2 text-gray-600"><%= t("orders.new.complete_order") %> <span class="font-semibold text-gray-900"><%= @event.name %></span></p>

  <%= form_with model: @order, url: event_orders_path(@event), method: :post, local: true, class: "mt-8 space-y-6" do |f| %>
    <!-- Order Summary -->
    <div class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-gray-200">
      <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
        <h2 class="text-lg font-bold text-gray-900"><%= t("orders.new.order_summary") %></h2>
      </div>

      <div class="p-6">
        <!-- Event Info -->
        <div class="mb-6 flex items-center gap-4 rounded-xl bg-indigo-50 p-4 ring-1 ring-indigo-100">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-indigo-600">
            <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900"><%= @event.name %></h3>
            <p class="text-sm text-gray-600">
              <%= l(@event.starts_at, format: :long) rescue @event.starts_at.strftime("%A, %B %d, %Y") %>
              &middot; <%= @event.venue&.name %>
            </p>
          </div>
        </div>

        <!-- Ticket Selection -->
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.new.select_tickets") %></h3>
        <div class="space-y-3">
          <% @event.ticket_types.each do |tt| %>
            <div class="flex items-center justify-between rounded-xl border border-gray-200 p-4 transition hover:border-indigo-300 hover:bg-indigo-50/50">
              <div class="flex-1">
                <div class="font-semibold text-gray-900"><%= tt.name %></div>
                <% if tt.description.present? %>
                  <div class="mt-0.5 text-sm text-gray-500"><%= tt.description %></div>
                <% end %>
                <div class="mt-1 text-sm font-bold text-indigo-600"><%= number_to_currency(tt.price) %> <%= t("orders.new.each") %></div>
                <% if tt.available_quantity > 0 %>
                  <div class="mt-0.5 text-xs text-gray-400"><%= t("orders.new.available", count: tt.available_quantity) %></div>
                <% end %>
              </div>
              <div class="ml-4">
                <% if tt.available_quantity > 0 %>
                  <input type="number"
                         name="ticket_quantities[<%= tt.id %>]"
                         min="0"
                         max="<%= [tt.available_quantity, tt.max_per_order].min %>"
                         value="<%= params.dig(:ticket_quantities, tt.id.to_s) || 0 %>"
                         class="w-20 rounded-lg border-0 text-center text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-500 sm:text-sm">
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-red-50 px-3 py-1 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20">
                    <%= t("events.show.sold_out") %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Order Total -->
      <div class="border-t border-gray-200 bg-gray-50 px-6 py-4">
        <div class="flex items-center justify-between">
          <span class="text-lg font-bold text-gray-900"><%= t("orders.new.estimated_total") %></span>
          <span class="text-2xl font-extrabold text-indigo-600" id="order-total">$0.00</span>
        </div>
        <p class="mt-1 text-xs text-gray-500"><%= t("orders.new.total_hint") %></p>
      </div>
    </div>

    <!-- Payment Note -->
    <div class="rounded-xl bg-amber-50 p-4 ring-1 ring-amber-200">
      <div class="flex items-start gap-3">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h4 class="text-sm font-semibold text-amber-800"><%= t("orders.new.payment_title") %></h4>
          <p class="mt-1 text-sm text-amber-700"><%= t("orders.new.payment_hint") %></p>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex items-center justify-end gap-4">
      <%= link_to t("orders.new.cancel"), event_path(@event),
          class: "rounded-lg bg-gray-100 px-6 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-200" %>
      <%= f.submit t("orders.new.place_order"),
          class: "rounded-lg bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
    </div>
  <% end %>
</div>

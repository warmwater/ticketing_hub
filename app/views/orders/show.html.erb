<%# Order Show - Order Details, Items, Tickets %>

<div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to orders_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("orders.show.back_to_orders") %>
    <% end %>
  </div>

  <!-- Order Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("orders.show.title") %></h1>
      <p class="mt-1 text-gray-500"><%= t("orders.show.reference", ref: @order.reference_number) %></p>
    </div>
    <div>
      <% status_classes = case @order.status
           when "confirmed" then "bg-green-50 text-green-700 ring-green-600/20"
           when "pending" then "bg-yellow-50 text-yellow-700 ring-yellow-600/20"
           when "cancelled" then "bg-red-50 text-red-700 ring-red-600/20"
           else "bg-gray-50 text-gray-700 ring-gray-600/20"
         end %>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset <%= status_classes %>">
        <%= t("statuses.#{@order.status}") %>
      </span>
    </div>
  </div>

  <!-- Event Info Card -->
  <div class="mt-6 overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-gray-200">
    <div class="flex items-center gap-4 bg-gradient-to-r from-indigo-600 to-purple-600 p-6">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-white/20">
        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-lg font-bold text-white"><%= @order.event.name %></h2>
        <p class="text-sm text-indigo-200">
          <%= l(@order.event.starts_at, format: :long) rescue @order.event.starts_at.strftime("%A, %B %d, %Y") %>
          &middot; <%= @order.event.venue&.name %>
        </p>
      </div>
    </div>

    <!-- Order Items Table -->
    <div class="p-6">
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.show.order_items") %></h3>

      <!-- Desktop Table -->
      <div class="hidden overflow-hidden rounded-lg ring-1 ring-gray-200 sm:block">
        <table class="w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.show.ticket_type") %></th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.show.qty") %></th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.show.unit_price") %></th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t("orders.show.subtotal") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @order.order_items.each do |item| %>
              <tr>
                <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= item.ticket_type.name %></td>
                <td class="px-4 py-3 text-center text-sm text-gray-600"><%= item.quantity %></td>
                <td class="px-4 py-3 text-right text-sm text-gray-600"><%= number_to_currency(item.unit_price) %></td>
                <td class="px-4 py-3 text-right text-sm font-semibold text-gray-900"><%= number_to_currency(item.total_price) %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-gray-50">
            <tr>
              <td colspan="3" class="px-4 py-3 text-right text-sm font-bold text-gray-900"><%= t("orders.show.total") %></td>
              <td class="px-4 py-3 text-right text-lg font-extrabold text-indigo-600"><%= number_to_currency(@order.total_amount) %></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Mobile Cards -->
      <div class="space-y-3 sm:hidden">
        <% @order.order_items.each do |item| %>
          <div class="rounded-lg border border-gray-200 p-4">
            <div class="flex items-center justify-between">
              <span class="font-semibold text-gray-900"><%= item.ticket_type.name %></span>
              <span class="font-bold text-indigo-600"><%= number_to_currency(item.total_price) %></span>
            </div>
            <div class="mt-1 text-sm text-gray-500">
              <%= item.quantity %> x <%= number_to_currency(item.unit_price) %>
            </div>
          </div>
        <% end %>
        <div class="flex items-center justify-between rounded-lg bg-gray-50 p-4">
          <span class="text-lg font-bold text-gray-900"><%= t("orders.show.total") %></span>
          <span class="text-xl font-extrabold text-indigo-600"><%= number_to_currency(@order.total_amount) %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Tickets -->
  <% if @order.tickets.any? %>
    <div class="mt-8">
      <h2 class="text-xl font-bold text-gray-900"><%= t("orders.show.your_tickets") %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t("orders.show.tickets_hint") %></p>

      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <% @order.tickets.each do |ticket| %>
          <%= link_to ticket_path(ticket), class: "block" do %>
            <div class="overflow-hidden rounded-xl bg-white shadow-md ring-1 ring-gray-200 transition hover:shadow-lg hover:ring-indigo-300">
              <div class="p-4">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-semibold text-gray-900"><%= ticket.ticket_type.name %></span>
                  <% ticket_status_classes = case ticket.status
                       when "active" then "bg-green-50 text-green-700 ring-green-600/20"
                       when "used" then "bg-gray-50 text-gray-700 ring-gray-600/20"
                       when "cancelled" then "bg-red-50 text-red-700 ring-red-600/20"
                       else "bg-gray-50 text-gray-700 ring-gray-600/20"
                     end %>
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= ticket_status_classes %>">
                    <%= t("statuses.#{ticket.status}") %>
                  </span>
                </div>
                <% if ticket.seat_label.present? %>
                  <div class="mt-2 flex items-center gap-1.5 text-sm text-indigo-700">
                    <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                    </svg>
                    <span class="font-medium"><%= ticket.seat_label %></span>
                  </div>
                <% end %>
                <div class="mt-3 rounded-lg bg-gray-50 p-3 text-center">
                  <p class="font-mono text-sm font-bold tracking-widest text-gray-700"><%= ticket.barcode %></p>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%# Reusable cover image upload field %>
<%# Locals: form (form builder), event (Event record) %>

<div data-controller="file-upload" class="space-y-3">
  <label class="block text-sm font-medium text-gray-700"><%= t("shared.media.cover_image") %></label>

  <% if event.cover_image.attached? %>
    <div class="relative inline-block">
      <%= image_tag event.cover_image.variant(resize_to_fill: [300, 200]),
          class: "rounded-lg border border-gray-200 shadow-sm" %>
      <div class="mt-2 flex items-center gap-2">
        <label class="flex items-center gap-1.5 text-sm text-red-600 cursor-pointer">
          <%= form.check_box :remove_cover_image, class: "rounded border-gray-300 text-red-600 focus:ring-red-500" %>
          <%= t("shared.media.remove_current") %>
        </label>
      </div>
    </div>
  <% end %>

  <div data-file-upload-target="dropzone"
       data-action="click->file-upload#selectFiles"
       class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer hover:border-indigo-400 transition">
    <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <p class="mt-2 text-sm text-gray-600">
      <span class="font-medium text-indigo-600"><%= t("shared.media.click_upload") %></span> <%= t("shared.media.or_drag") %>
    </p>
    <p class="mt-1 text-xs text-gray-500"><%= t("shared.media.image_formats") %></p>
  </div>

  <%= form.file_field :cover_image,
      accept: "image/jpeg,image/png,image/gif,image/webp",
      direct_upload: true,
      data: { file_upload_target: "input", action: "change->file-upload#handleFileSelect" },
      class: "hidden" %>

  <div data-file-upload-target="preview" class="flex flex-wrap"></div>
</div>

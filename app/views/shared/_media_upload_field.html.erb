<%# Reusable media gallery upload field %>
<%# Locals: form (form builder), event (Event record), purge_path (lambda for purge URL) %>

<div data-controller="file-upload" data-file-upload-multiple-value="true" class="space-y-3">
  <label class="block text-sm font-medium text-gray-700">Photos & Videos</label>

  <% if event.media.attached? %>
    <div class="grid grid-cols-3 sm:grid-cols-4 gap-3 mb-4">
      <% event.media.each do |file| %>
        <div class="relative group">
          <% if event.image?(file) %>
            <%= image_tag file.variant(resize_to_fill: [150, 150]),
                class: "w-full aspect-square object-cover rounded-lg border border-gray-200" %>
          <% else %>
            <div class="w-full aspect-square rounded-lg border border-gray-200 bg-gray-100 flex items-center justify-center flex-col p-2">
              <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="mt-1 text-xs text-gray-500 truncate w-full text-center"><%= file.filename %></p>
            </div>
          <% end %>

          <%= link_to "Remove",
              purge_path.call(event, attachment_id: file.id),
              data: { turbo_method: :delete, turbo_confirm: "Remove this file?" },
              class: "absolute top-1 right-1 bg-red-600 text-white text-xs px-2 py-1 rounded-md opacity-0 group-hover:opacity-100 transition shadow" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div data-file-upload-target="dropzone"
       data-action="click->file-upload#selectFiles"
       class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer hover:border-indigo-400 transition">
    <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
    </svg>
    <p class="mt-2 text-sm text-gray-600">
      <span class="font-medium text-indigo-600">Click to upload</span> or drag and drop
    </p>
    <p class="mt-1 text-xs text-gray-500">Images (JPEG, PNG, GIF, WebP up to 10MB) or Videos (MP4, WebM, MOV up to 100MB)</p>
  </div>

  <%= form.file_field :media,
      multiple: true,
      accept: "image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime",
      direct_upload: true,
      data: { file_upload_target: "input", action: "change->file-upload#handleFileSelect" },
      class: "hidden" %>

  <div data-file-upload-target="preview" class="flex flex-wrap"></div>
</div>

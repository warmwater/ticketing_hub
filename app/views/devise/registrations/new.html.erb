<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-indigo-600">TicketHub</h1>
      <h2 class="mt-2 text-xl text-gray-700"><%= t("auth.registrations.new.title") %></h2>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, t("auth.registrations.new.name"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, autofocus: true, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t("auth.registrations.new.name_placeholder") %>
        </div>

        <div>
          <%= f.label :email, t("auth.registrations.new.email"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.email_field :email, autocomplete: "email", class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t("auth.registrations.new.email_placeholder") %>
        </div>

        <div>
          <%= f.label :role, t("auth.registrations.new.role_label"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :role, [[t("auth.registrations.new.role_attendant"), "attendant"], [t("auth.registrations.new.role_organizer"), "organizer"]], {}, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :phone, t("auth.registrations.new.phone"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.phone_field :phone, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: t("auth.registrations.new.phone_placeholder") %>
        </div>

        <div>
          <%= f.label :password, t("auth.registrations.new.password"), class: "block text-sm font-medium text-gray-700" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500"><%= t("auth.registrations.new.characters_minimum", count: @minimum_password_length) %></p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, t("auth.registrations.new.password_confirmation"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <div class="pt-2">
          <%= f.submit t("auth.registrations.new.sign_up"), class: "w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 transition cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 text-center text-sm text-gray-500">
        <%= t("auth.registrations.new.have_account") %>
        <%= link_to t("auth.registrations.new.sign_in"), new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
      </div>
    </div>
  </div>
</div>

<%# Events Index - Search, Filter, Grid %>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Events</h1>
    <p class="mt-2 text-gray-600">Browse and discover upcoming events</p>
  </div>

  <!-- Search & Filters -->
  <div class="mb-8 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-200 sm:p-6">
    <%= form_with url: events_path, method: :get, local: true, class: "space-y-4" do |f| %>
      <!-- Search Bar -->
      <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <%= f.text_field :q,
            value: params[:q],
            placeholder: "Search events, artists, venues...",
            class: "w-full rounded-lg border-0 py-3 pl-10 pr-4 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <!-- Filter Row -->
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
        <div class="flex-1">
          <label for="date_from" class="block text-sm font-medium text-gray-700">From Date</label>
          <%= f.date_field :date_from,
              value: params[:date_from],
              class: "mt-1 w-full rounded-lg border-0 py-2 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        </div>
        <div class="flex-1">
          <label for="date_to" class="block text-sm font-medium text-gray-700">To Date</label>
          <%= f.date_field :date_to,
              value: params[:date_to],
              class: "mt-1 w-full rounded-lg border-0 py-2 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        </div>
        <div class="flex-1">
          <label for="sort" class="block text-sm font-medium text-gray-700">Sort By</label>
          <%= f.select :sort,
              options_for_select([
                ["Date (Soonest)", "date_asc"],
                ["Date (Latest)", "date_desc"],
                ["Name (A-Z)", "name_asc"],
                ["Name (Z-A)", "name_desc"],
                ["Price (Low-High)", "price_asc"],
                ["Price (High-Low)", "price_desc"]
              ], params[:sort]),
              {},
              class: "mt-1 w-full rounded-lg border-0 py-2 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        </div>
        <div class="flex gap-2">
          <%= f.submit "Search",
              class: "rounded-lg bg-indigo-600 px-6 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
          <%= link_to "Clear", events_path,
              class: "rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-200" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Results Count -->
  <% if @events.any? %>
    <p class="mb-4 text-sm text-gray-500">
      Showing <%= @events.length %> event<%= @events.length == 1 ? "" : "s" %>
    </p>
  <% end %>

  <!-- Events Grid -->
  <% if @events.any? %>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @events.each do |event| %>
        <div class="group relative overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-200 transition hover:shadow-xl hover:ring-indigo-300">
          <!-- Event Image Placeholder -->
          <div class="relative h-44 bg-gradient-to-br from-indigo-500 to-purple-600">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="h-14 w-14 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="absolute bottom-3 left-3">
              <span class="inline-flex items-center rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-indigo-700 backdrop-blur-sm">
                <%= event.starts_at.strftime("%b %d, %Y") %>
              </span>
            </div>
          </div>

          <!-- Event Details -->
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-indigo-600 transition">
              <%= event.name %>
            </h3>
            <div class="mt-2 flex items-center gap-1 text-sm text-gray-500">
              <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="truncate"><%= event.venue&.name %></span>
            </div>

            <% if event.ticket_types.any? %>
              <div class="mt-3 flex items-center gap-1 text-sm font-semibold text-indigo-600">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                </svg>
                <span>
                  From <%= number_to_currency(event.ticket_types.minimum(:price)) %>
                  <% if event.ticket_types.minimum(:price) != event.ticket_types.maximum(:price) %>
                    &ndash; <%= number_to_currency(event.ticket_types.maximum(:price)) %>
                  <% end %>
                </span>
              </div>
            <% end %>

            <div class="mt-4">
              <%= link_to "View Event", event_path(event),
                  class: "inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <nav class="mt-10 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </nav>
  <% else %>
    <!-- Empty State -->
    <div class="rounded-2xl border-2 border-dashed border-gray-300 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3 class="mt-4 text-lg font-semibold text-gray-900">No events found</h3>
      <p class="mt-2 text-gray-500">Try adjusting your search or filters to find what you're looking for.</p>
      <div class="mt-6">
        <%= link_to "Clear Filters", events_path,
            class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      </div>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-2xl shadow-lg p-8 text-center" id="waiting_room_status">
  <div class="mb-6">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100">
      <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>
  </div>

  <h2 class="text-2xl font-bold text-green-700 mb-2">You're in!</h2>
  <p class="text-gray-600 mb-4">It's your turn to purchase tickets.</p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
    <p class="text-amber-800 text-sm font-medium">Time remaining to complete your purchase:</p>
    <p class="text-3xl font-bold text-amber-700 mt-1" data-waiting-room-target="countdown">
      <%= entry.minutes_remaining %>:00
    </p>
  </div>

  <%= link_to new_event_order_path(event), class: "inline-block bg-green-600 text-white px-8 py-3 rounded-xl font-semibold hover:bg-green-700 transition text-lg" do %>
    Continue to Purchase &rarr;
  <% end %>
</div>

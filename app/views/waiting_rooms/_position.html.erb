<div class="bg-white rounded-2xl shadow-lg p-8 text-center" id="waiting_room_status">
  <!-- Animated spinner -->
  <div class="mb-6">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-indigo-100 animate-pulse">
      <svg class="w-10 h-10 text-indigo-600 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
  </div>

  <h2 class="text-xl font-semibold text-gray-900 mb-2">You're in the queue!</h2>

  <div class="my-6">
    <p class="text-sm text-gray-500 uppercase tracking-wide">Your Position</p>
    <p class="text-5xl font-bold text-indigo-600 my-2" data-waiting-room-target="position"><%= position %></p>
    <p class="text-sm text-gray-500">of <span data-waiting-room-target="total"><%= total %></span> in queue</p>
  </div>

  <!-- Progress indicator -->
  <div class="w-full bg-gray-200 rounded-full h-2 mb-4">
    <% progress = total > 0 ? ((total - position + 1).to_f / total * 100) : 0 %>
    <div class="bg-indigo-600 h-2 rounded-full transition-all duration-500" style="width: <%= progress %>%"></div>
  </div>

  <p class="text-sm text-gray-500">Please keep this page open. You'll be automatically redirected when it's your turn.</p>
</div>

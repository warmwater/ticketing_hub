<% if @entry.nil? %>
  <%= turbo_stream.replace "waiting_room_status" do %>
    <div id="waiting_room_status" class="bg-white rounded-2xl shadow-lg p-8 text-center">
      <p class="text-gray-600">You are not in the waiting room.</p>
    </div>
  <% end %>
<% elsif @entry.admitted? && !@entry.admission_expired? %>
  <%= turbo_stream.replace "waiting_room_status" do %>
    <%= render "waiting_rooms/admitted", entry: @entry, event: @event %>
  <% end %>
<% elsif @entry.waiting? %>
  <%= turbo_stream.replace "waiting_room_status" do %>
    <%= render "waiting_rooms/position", entry: @entry, position: @entry.queue_position, total: @entry.total_waiting %>
  <% end %>
<% end %>

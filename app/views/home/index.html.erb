<%# Home Page - Hero + Featured Events %>

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-indigo-900 via-indigo-800 to-purple-900">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>
  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        <%= t("home.index.title_line1") %>
        <span class="block bg-gradient-to-r from-indigo-300 to-purple-300 bg-clip-text text-transparent">
          <%= t("home.index.title_line2") %>
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-indigo-200">
        <%= t("home.index.subtitle") %>
      </p>

      <!-- Search Bar -->
      <div class="mx-auto mt-10 max-w-2xl">
        <%= form_with url: events_path, method: :get, local: true, class: "flex items-center gap-2" do |f| %>
          <div class="relative flex-1">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <%= f.text_field :q,
                placeholder: t("home.index.search_placeholder"),
                class: "w-full rounded-xl border-0 py-4 pl-12 pr-4 text-gray-900 shadow-lg ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-500 sm:text-lg",
                autofocus: true %>
          </div>
          <%= f.submit t("home.index.search"),
              class: "rounded-xl bg-indigo-500 px-8 py-4 text-lg font-semibold text-white shadow-lg transition hover:bg-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:ring-offset-2 cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Featured Events -->
<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-10 flex items-center justify-between">
    <div>
      <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("home.index.featured_events") %></h2>
      <p class="mt-2 text-gray-600"><%= t("home.index.featured_subtitle") %></p>
    </div>
    <%= link_to events_path, class: "hidden sm:inline-flex items-center gap-1 text-indigo-600 font-semibold hover:text-indigo-500 transition" do %>
      <%= t("home.index.view_all_events") %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>

  <%= turbo_frame_tag "featured_events" do %>
    <% if @featured_events.present? %>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @featured_events.each do |event| %>
          <div class="group relative overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-200 transition hover:shadow-xl hover:ring-indigo-300">
            <!-- Event Image Placeholder -->
            <div class="relative h-48 bg-gradient-to-br from-indigo-500 to-purple-600">
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="h-16 w-16 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="absolute bottom-3 left-3">
                <span class="inline-flex items-center rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-indigo-700 backdrop-blur-sm">
                  <%= event.starts_at.strftime("%b %d, %Y") %>
                </span>
              </div>
            </div>

            <!-- Event Details -->
            <div class="p-5">
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-indigo-600 transition">
                <%= event.name %>
              </h3>
              <div class="mt-2 flex items-center gap-1 text-sm text-gray-500">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="truncate"><%= event.venue&.name %></span>
              </div>

              <% if event.ticket_types.any? %>
                <div class="mt-3 flex items-center gap-1 text-sm font-semibold text-indigo-600">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                  </svg>
                  <span>
                    <%= t("home.index.from") %> <%= number_to_currency(event.ticket_types.minimum(:price)) %>
                    <% if event.ticket_types.minimum(:price) != event.ticket_types.maximum(:price) %>
                      &ndash; <%= number_to_currency(event.ticket_types.maximum(:price)) %>
                    <% end %>
                  </span>
                </div>
              <% end %>

              <div class="mt-4">
                <%= link_to t("home.index.view_event"), event_path(event),
                    data: { turbo_frame: "_top" },
                    class: "inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl border-2 border-dashed border-gray-300 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-4 text-lg font-semibold text-gray-900"><%= t("home.index.no_featured") %></h3>
        <p class="mt-2 text-gray-500"><%= t("home.index.check_back") %></p>
      </div>
    <% end %>
  <% end %>

  <!-- Mobile View All Link -->
  <div class="mt-8 text-center sm:hidden">
    <%= link_to events_path, class: "inline-flex items-center gap-1 text-indigo-600 font-semibold hover:text-indigo-500 transition" do %>
      <%= t("home.index.view_all_events") %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>
</section>

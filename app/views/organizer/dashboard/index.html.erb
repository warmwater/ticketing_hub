<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Welcome Message %>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Welcome back, <%= current_user.name %>!</h1>
    <p class="mt-1 text-sm text-gray-500">Here's an overview of your events and ticket sales.</p>
  </div>

  <%# Stats Cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-indigo-500">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-indigo-100 rounded-full p-3">
          <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500"><%= t("organizer.dashboard.total_events") %></p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_events %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-purple-500">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-purple-100 rounded-full p-3">
          <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500"><%= t("organizer.dashboard.tickets_sold") %></p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_tickets_sold %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-indigo-400">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-indigo-100 rounded-full p-3">
          <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500"><%= t("organizer.dashboard.upcoming_events") %></p>
          <p class="text-2xl font-bold text-gray-900"><%= @upcoming_events.count %></p>
        </div>
      </div>
    </div>
  </div>

  <%# Create New Event Button %>
  <div class="mb-8">
    <%= link_to new_organizer_event_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition" do %>
      <svg class="h-5 w-5 mr-2 -ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <%= t("organizer.dashboard.create_event") %>
    <% end %>
  </div>

  <%# Upcoming Events %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("organizer.dashboard.upcoming_events_list") %></h2>
    </div>
    <% if @upcoming_events.any? %>
      <ul class="divide-y divide-gray-200">
        <% @upcoming_events.each do |event| %>
          <li class="px-6 py-4 hover:bg-gray-50 transition">
            <div class="flex items-center justify-between">
              <div>
                <%= link_to event.name, organizer_event_path(event), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
                <p class="text-sm text-gray-500 mt-1">
                  <%= l(event.starts_at, format: :datetime_long) %>
                  <% if event.venue %>
                    &middot; <%= event.venue.name %>
                  <% end %>
                </p>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <% case event.status %>
                <% when 'draft' %>
                  bg-gray-100 text-gray-800
                <% when 'published' %>
                  bg-green-100 text-green-800
                <% when 'cancelled' %>
                  bg-red-100 text-red-800
                <% when 'completed' %>
                  bg-blue-100 text-blue-800
                <% end %>
              ">
                <%= t("statuses.#{event.status}") %>
              </span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500"><%= t("organizer.dashboard.no_upcoming") %></p>
      </div>
    <% end %>
  </div>

  <%# Recent Events Table %>
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("organizer.dashboard.recent_events") %></h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.dashboard.name") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.dashboard.status") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.dashboard.date") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.dashboard.tickets_sold") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @events.each do |event| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to event.name, organizer_event_path(event), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <% case event.status %>
                  <% when 'draft' %>
                    bg-gray-100 text-gray-800
                  <% when 'published' %>
                    bg-green-100 text-green-800
                  <% when 'cancelled' %>
                    bg-red-100 text-red-800
                  <% when 'completed' %>
                    bg-blue-100 text-blue-800
                  <% end %>
                ">
                  <%= t("statuses.#{event.status}") %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= l(event.starts_at, format: :short) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= event.tickets_sold %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

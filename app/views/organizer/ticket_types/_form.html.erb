<div class="bg-white rounded-xl shadow p-6">
  <%= form_with model: [:organizer, @event, ticket_type], class: "space-y-4" do |f| %>
    <% if ticket_type.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="text-red-700 text-sm list-disc pl-4">
          <% ticket_type.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 3, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :price, class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :price, step: 0.01, min: 0, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :quantity, class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :quantity, min: 1, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div>
      <%= f.label :max_per_order, "Max per order", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :max_per_order, min: 1, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :sale_starts_at, "Sale starts", class: "block text-sm font-medium text-gray-700" %>
        <%= f.datetime_local_field :sale_starts_at, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :sale_ends_at, "Sale ends", class: "block text-sm font-medium text-gray-700" %>
        <%= f.datetime_local_field :sale_ends_at, class: "mt-1 w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div class="flex gap-3 pt-4">
      <%= f.submit class: "bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Cancel", organizer_event_path(@event), class: "px-6 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>

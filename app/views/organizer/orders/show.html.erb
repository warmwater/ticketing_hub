<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("organizer.orders.show.title") %> <%= @order.reference_number %></h1>
    <%= link_to "&larr; #{t('organizer.orders.show.back')}".html_safe, organizer_orders_path, class: "text-indigo-600 hover:text-indigo-800 text-sm" %>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div>
        <dt class="text-sm text-gray-500"><%= t("organizer.orders.show.event") %></dt>
        <dd class="font-medium"><%= @order.event.name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t("organizer.orders.show.buyer") %></dt>
        <dd class="font-medium"><%= @order.user.name %><br><span class="text-sm text-gray-500"><%= @order.user.email %></span></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t("organizer.orders.show.status") %></dt>
        <dd>
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium
            <%= @order.confirmed? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
            <%= t("statuses.#{@order.status}") %>
          </span>
        </dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t("organizer.orders.show.total") %></dt>
        <dd class="text-lg font-bold text-indigo-600"><%= number_to_currency(@order.total_amount) %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold mb-4"><%= t("organizer.orders.show.order_items") %></h2>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left text-gray-500">
          <th class="pb-2"><%= t("organizer.orders.show.ticket_type") %></th>
          <th class="pb-2"><%= t("organizer.orders.show.qty") %></th>
          <th class="pb-2"><%= t("organizer.orders.show.unit_price") %></th>
          <th class="pb-2"><%= t("organizer.orders.show.subtotal") %></th>
        </tr>
      </thead>
      <tbody>
        <% @order.order_items.each do |item| %>
          <tr class="border-b">
            <td class="py-3 font-medium"><%= item.ticket_type.name %></td>
            <td class="py-3"><%= item.quantity %></td>
            <td class="py-3"><%= number_to_currency(item.unit_price) %></td>
            <td class="py-3"><%= number_to_currency(item.total_price) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold mb-4"><%= t("organizer.orders.show.tickets") %></h2>
    <div class="space-y-2">
      <% @order.order_items.each do |item| %>
        <% item.tickets.each do |ticket| %>
          <div class="flex items-center justify-between border rounded-lg p-3">
            <div>
              <span class="font-medium"><%= item.ticket_type.name %></span>
              <span class="text-gray-500 text-sm ml-2"><%= ticket.attendee_name %></span>
            </div>
            <div class="flex items-center gap-3">
              <code class="text-xs bg-gray-100 px-2 py-1 rounded"><%= ticket.barcode %></code>
              <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
                <%= ticket.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= t("statuses.#{ticket.status}") %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

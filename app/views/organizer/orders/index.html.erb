<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("organizer.orders.index.title") %></h1>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr class="text-left text-gray-500 uppercase text-xs tracking-wide">
          <th class="px-6 py-3"><%= t("organizer.orders.index.reference") %></th>
          <th class="px-6 py-3"><%= t("organizer.orders.index.event") %></th>
          <th class="px-6 py-3"><%= t("organizer.orders.index.buyer") %></th>
          <th class="px-6 py-3"><%= t("organizer.orders.index.status") %></th>
          <th class="px-6 py-3"><%= t("organizer.orders.index.total") %></th>
          <th class="px-6 py-3"><%= t("organizer.orders.index.date") %></th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 font-mono text-xs"><%= order.reference_number %></td>
            <td class="px-6 py-4"><%= order.event.name %></td>
            <td class="px-6 py-4"><%= order.user.name %></td>
            <td class="px-6 py-4">
              <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
                <%= case order.status
                    when 'confirmed' then 'bg-green-100 text-green-800'
                    when 'pending' then 'bg-yellow-100 text-yellow-800'
                    when 'cancelled' then 'bg-red-100 text-red-800'
                    end %>">
                <%= t("statuses.#{order.status}") %>
              </span>
            </td>
            <td class="px-6 py-4"><%= number_to_currency(order.total_amount) %></td>
            <td class="px-6 py-4 text-gray-500"><%= order.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4">
              <%= link_to t("organizer.orders.index.view"), organizer_order_path(order), class: "text-indigo-600 hover:text-indigo-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%== pagy_nav(@pagy) %>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Back Link %>
  <div class="mb-6">
    <%= link_to organizer_events_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= t("organizer.events.show.back") %>
    <% end %>
  </div>

  <%# Event Header %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-6">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="flex items-center space-x-3">
            <h1 class="text-3xl font-bold text-gray-900"><%= @event.name %></h1>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
              <% case @event.status %>
              <% when 'draft' %>
                bg-gray-100 text-gray-800
              <% when 'published' %>
                bg-green-100 text-green-800
              <% when 'cancelled' %>
                bg-red-100 text-red-800
              <% when 'completed' %>
                bg-blue-100 text-blue-800
              <% end %>
            ">
              <%= t("statuses.#{@event.status}") %>
            </span>
          </div>

          <% if @event.description.present? %>
            <p class="mt-3 text-gray-600"><%= @event.description %></p>
          <% end %>

          <div class="mt-4 space-y-2">
            <% if @event.venue %>
              <div class="flex items-center text-sm text-gray-500">
                <svg class="h-5 w-5 mr-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <%= @event.venue.name %>
              </div>
            <% end %>
            <div class="flex items-center text-sm text-gray-500">
              <svg class="h-5 w-5 mr-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <%= l(@event.starts_at, format: :datetime_long) %>
              <% if @event.ends_at %>
                &mdash; <%= l(@event.ends_at, format: :datetime_long) %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%# Action Buttons Row %>
      <div class="mt-6 flex flex-wrap gap-3 pt-4 border-t border-gray-200">
        <%= link_to edit_organizer_event_path(@event), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition" do %>
          <svg class="h-4 w-4 mr-2 -ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          <%= t("organizer.events.show.edit") %>
        <% end %>

        <% if @event.status == 'draft' %>
          <%= link_to publish_organizer_event_path(@event), data: { turbo_method: :patch }, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition" do %>
            <svg class="h-4 w-4 mr-2 -ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= t("organizer.events.show.publish") %>
          <% end %>
        <% end %>

        <% unless @event.status == 'cancelled' %>
          <%= link_to cancel_organizer_event_path(@event), data: { turbo_method: :patch, turbo_confirm: t("organizer.events.show.cancel_confirm") }, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition" do %>
            <svg class="h-4 w-4 mr-2 -ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <%= t("organizer.events.show.cancel_event") %>
          <% end %>
        <% end %>

        <%= link_to toggle_waiting_room_organizer_event_path(@event), data: { turbo_method: :patch }, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white #{@event.waiting_room_enabled? ? 'bg-orange-600 hover:bg-orange-700 focus:ring-orange-500' : 'bg-purple-600 hover:bg-purple-700 focus:ring-purple-500'} focus:outline-none focus:ring-2 focus:ring-offset-2 transition" do %>
          <svg class="h-4 w-4 mr-2 -ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= @event.waiting_room_enabled? ? t("organizer.events.show.disable_wr") : t("organizer.events.show.enable_wr") %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Waiting Room Stats %>
  <% if @event.waiting_room_enabled? %>
    <div class="bg-purple-50 border border-purple-200 rounded-lg shadow mb-8 p-6">
      <div class="flex items-center">
        <div class="flex-shrink-0 bg-purple-100 rounded-full p-3">
          <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-purple-900"><%= t("organizer.events.show.waiting_room") %></h3>
          <p class="text-purple-700"><%= t("organizer.events.show.users_waiting", count: @waiting_count) %></p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Ticket Types Section %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900"><%= t("organizer.events.show.ticket_types") %></h2>
        <% if @event.seated_event? %>
          <p class="text-xs text-gray-500 mt-0.5">
            <%= t("organizer.events.show.seating_mode") %>
            <span class="font-medium text-indigo-600">
              <%= @event.seating_customer_pick? ? t("organizer.events.show.customer_picks") : t("organizer.events.show.auto_assign") %>
            </span>
          </p>
        <% end %>
      </div>
      <%= link_to new_organizer_event_ticket_type_path(@event), class: "inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition" do %>
        <svg class="h-4 w-4 mr-1.5 -ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t("organizer.events.show.add_ticket_type") %>
      <% end %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.name") %></th>
            <% if @sections.present? %>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.section") %></th>
            <% end %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.price") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.quantity") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.sold") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.available") %></th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.actions") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @ticket_types.each do |ticket_type| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= ticket_type.name %>
              </td>
              <% if @sections.present? %>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if ticket_type.section %>
                    <span class="inline-flex items-center gap-1">
                      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset
                        <%= ticket_type.section.general_admission? ? 'bg-blue-50 text-blue-700 ring-blue-600/20' : 'bg-purple-50 text-purple-700 ring-purple-600/20' %>">
                        <%= ticket_type.section.name %>
                      </span>
                    </span>
                  <% else %>
                    <span class="text-gray-400">&mdash;</span>
                  <% end %>
                </td>
              <% end %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= number_to_currency(ticket_type.price) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= ticket_type.quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= ticket_type.quantity - ticket_type.available_quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= ticket_type.available_quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                <%= link_to t("organizer.events.show.edit"), edit_organizer_event_ticket_type_path(@event, ticket_type), class: "text-indigo-600 hover:text-indigo-900" %>
                <%= link_to t("organizer.events.show.delete"), organizer_event_ticket_type_path(@event, ticket_type), data: { turbo_method: :delete, turbo_confirm: t("organizer.events.show.delete_confirm") }, class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @ticket_types.empty? %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500"><%= t("organizer.events.show.no_ticket_types") %></p>
      </div>
    <% end %>
  </div>

  <%# Seating Layout %>
  <% if @sections.present? %>
    <div class="bg-white rounded-lg shadow mb-8">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <h2 class="text-lg font-semibold text-gray-900"><%= t("organizer.events.show.seating_layout") %></h2>
        </div>
        <span class="text-sm text-gray-500"><%= t("organizer.events.show.sections_count", count: @sections.size) %></span>
      </div>

      <div class="p-6">
        <!-- Legend -->
        <div class="flex flex-wrap items-center gap-4 text-sm mb-5">
          <div class="flex items-center gap-1.5">
            <div class="h-4 w-4 rounded bg-emerald-500 ring-1 ring-emerald-600"></div>
            <span class="text-gray-600"><%= t("organizer.events.show.available") %></span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-4 w-4 rounded bg-rose-500 ring-1 ring-rose-600"></div>
            <span class="text-gray-600"><%= t("organizer.events.show.sold_label") %></span>
          </div>
        </div>

        <div class="space-y-5">
          <% @sections.each do |section| %>
            <div class="rounded-xl border border-gray-200 p-5">
              <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                <div class="flex items-center gap-3">
                  <h3 class="font-semibold text-gray-900"><%= section.name %></h3>
                  <% if section.general_admission? %>
                    <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20"><%= t("organizer.events.show.ga") %></span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-600/20"><%= t("organizer.events.show.seated") %></span>
                  <% end %>
                </div>

                <% if section.general_admission? %>
                  <% available_ga = section.available_capacity_for_event(@event) %>
                  <% sold_ga = section.capacity - available_ga %>
                  <div class="text-sm">
                    <span class="font-semibold text-gray-900"><%= sold_ga %></span>
                    <span class="text-gray-500">/ <%= section.capacity %> sold</span>
                  </div>
                <% else %>
                  <% available_seats = section.available_seats_for_event(@event) %>
                  <% total_seats = section.active_seats.count %>
                  <% sold_seats = total_seats - available_seats.count %>
                  <div class="text-sm">
                    <span class="font-semibold text-gray-900"><%= sold_seats %></span>
                    <span class="text-gray-500">/ <%= total_seats %> sold</span>
                  </div>
                <% end %>
              </div>

              <% if section.seated? && section.seats.any? %>
                <% available_seat_ids = section.available_seats_for_event(@event).pluck(:id) %>
                <div class="overflow-x-auto">
                  <div class="inline-block rounded-lg bg-gray-50 p-4 min-w-fit">
                    <!-- Stage indicator -->
                    <div class="mb-3 text-center">
                      <div class="inline-block rounded-t-xl bg-gray-300 px-12 py-1.5 text-xs font-semibold uppercase tracking-widest text-gray-600"><%= t("organizer.events.show.stage") %></div>
                    </div>

                    <% section.rows.each do |row_label, seats| %>
                      <div class="flex items-center gap-0.5 mb-0.5">
                        <span class="w-6 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                        <% seats.each do |seat| %>
                          <% available = available_seat_ids.include?(seat.id) %>
                          <div class="h-5 w-5 rounded text-center text-[10px] leading-5 font-medium
                            <%= available ? 'bg-emerald-500 text-white ring-1 ring-emerald-600' : 'bg-rose-500 text-white ring-1 ring-rose-600' %>"
                               title="<%= available ? t('organizer.events.show.available') : t('organizer.events.show.sold_label') %> — Row <%= seat.row_label %>, Seat <%= seat.seat_number %>">
                            <%= seat.seat_number %>
                          </div>
                        <% end %>
                        <span class="w-6 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% elsif section.general_admission? %>
                <% available_ga = section.available_capacity_for_event(@event) %>
                <% sold_ga = section.capacity - available_ga %>
                <% pct = section.capacity > 0 ? (sold_ga.to_f / section.capacity * 100).round : 0 %>
                <div class="mt-2">
                  <div class="h-3 w-full rounded-full bg-gray-200 overflow-hidden">
                    <div class="h-full rounded-full <%= pct >= 90 ? 'bg-red-500' : pct >= 70 ? 'bg-amber-500' : 'bg-green-500' %>" style="width: <%= pct %>%"></div>
                  </div>
                  <div class="mt-1 flex items-center justify-between text-xs text-gray-500">
                    <span><%= t("organizer.events.show.pct_sold", pct: pct) %></span>
                    <span><%= t("organizer.events.show.remaining", count: available_ga) %></span>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Recent Orders %>
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("organizer.events.show.recent_orders") %></h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.reference") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.buyer") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.status") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.total") %></th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("organizer.events.show.date") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_orders.each do |order| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <%= link_to order.reference_number, organizer_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.user&.name || order.user&.email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <% case order.status %>
                  <% when 'confirmed' %>
                    bg-green-100 text-green-800
                  <% when 'pending' %>
                    bg-yellow-100 text-yellow-800
                  <% when 'cancelled' %>
                    bg-red-100 text-red-800
                  <% end %>
                ">
                  <%= t("statuses.#{order.status}") %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= number_to_currency(order.total_amount) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= l(order.created_at, format: :short) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @recent_orders.empty? %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500"><%= t("organizer.events.show.no_orders") %></p>
      </div>
    <% end %>
  </div>
</div>

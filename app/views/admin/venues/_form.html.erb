<div class="bg-white rounded-lg shadow overflow-hidden max-w-2xl">
  <%= form_with model: venue, url: venue.persisted? ? admin_venue_path(venue) : admin_venues_path, class: "p-6 space-y-6" do |f| %>

    <% if venue.errors.any? %>
      <div class="rounded-lg bg-red-50 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= t("admin.venues.form.errors_title", count: venue.errors.count) %>
            </h3>
            <ul class="mt-2 list-disc list-inside text-sm text-red-700">
              <% venue.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :name, t("admin.venues.form.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.name") %>
    </div>

    <div>
      <%= f.label :address, t("admin.venues.form.address"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :address, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.address") %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :city, t("admin.venues.form.city"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :city, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.city") %>
      </div>
      <div>
        <%= f.label :state, t("admin.venues.form.state"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :state, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.state") %>
      </div>
      <div>
        <%= f.label :country, t("admin.venues.form.country"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :country, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.country") %>
      </div>
    </div>

    <div>
      <%= f.label :capacity, t("admin.venues.form.capacity"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :capacity, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.capacity"), min: 0 %>
    </div>

    <div>
      <%= f.label :description, t("admin.venues.form.description"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 4, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: t("admin.venues.form.description") %>
    </div>

    <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-200">
      <%= link_to t("admin.venues.form.cancel"), admin_venues_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
      <%= f.submit t("admin.venues.form.save"), class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition cursor-pointer" %>
    </div>
  <% end %>
</div>

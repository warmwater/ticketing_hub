<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("admin.venues.index.title") %></h1>
    <%= link_to t("admin.venues.index.new_venue"), new_admin_venue_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition" %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.venues.index.name") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.venues.index.city") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.venues.index.country") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.venues.index.capacity") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.venues.index.actions") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @venues.each do |venue| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-indigo-600">
                <%= link_to venue.name, admin_venue_path(venue), class: "hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= venue.city %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= venue.country %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= number_with_delimiter(venue.capacity) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                <%= link_to t("admin.venues.index.view"), admin_venue_path(venue), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                <%= link_to t("admin.venues.index.edit"), edit_admin_venue_path(venue), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                <%= link_to t("admin.venues.index.delete"), admin_venue_path(venue), data: { turbo_method: :delete, turbo_confirm: t("admin.venues.index.delete_confirm") }, class: "text-red-600 hover:text-red-900 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-4">
    <%== pagy_nav(@pagy) %>
  </div>
</div>

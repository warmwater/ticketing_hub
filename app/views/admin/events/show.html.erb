<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= @event.name %></h1>
    <div class="flex gap-2">
      <% if @event.draft? %>
        <%= link_to "Publish", publish_admin_event_path(@event), data: { turbo_method: :patch, turbo_confirm: "Publish this event?" }, class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 text-sm" %>
      <% end %>
      <% unless @event.cancelled? %>
        <%= link_to "Cancel Event", cancel_admin_event_path(@event), data: { turbo_method: :patch, turbo_confirm: "Cancel this event?" }, class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 text-sm" %>
      <% end %>
      <%= link_to "Edit", edit_admin_event_path(@event), class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-sm" %>
    </div>
  </div>

  <!-- Event Details -->
  <div class="bg-white rounded-xl shadow p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <dt class="text-sm text-gray-500">Status</dt>
        <dd class="mt-1">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium
            <%= case @event.status
                when 'draft' then 'bg-gray-100 text-gray-800'
                when 'published' then 'bg-green-100 text-green-800'
                when 'cancelled' then 'bg-red-100 text-red-800'
                when 'completed' then 'bg-blue-100 text-blue-800'
                end %>">
            <%= @event.status.capitalize %>
          </span>
        </dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Organizer</dt>
        <dd class="font-medium"><%= @event.organizer.name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Venue</dt>
        <dd class="font-medium"><%= @event.venue.name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Dates</dt>
        <dd class="font-medium"><%= @event.starts_at.strftime("%b %d, %Y %I:%M %p") %> &mdash; <%= @event.ends_at.strftime("%b %d, %Y %I:%M %p") %></dd>
      </div>
      <div class="md:col-span-2">
        <dt class="text-sm text-gray-500">Description</dt>
        <dd class="mt-1 text-gray-700"><%= @event.description %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Waiting Room</dt>
        <dd class="font-medium"><%= @event.waiting_room_enabled? ? "Enabled (capacity: #{@event.waiting_room_capacity})" : "Disabled" %></dd>
      </div>
    </dl>
  </div>

  <!-- Ticket Types -->
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold mb-4">Ticket Types</h2>
    <% if @ticket_types.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-gray-500">
            <th class="pb-2">Name</th>
            <th class="pb-2">Price</th>
            <th class="pb-2">Quantity</th>
            <th class="pb-2">Available</th>
          </tr>
        </thead>
        <tbody>
          <% @ticket_types.each do |tt| %>
            <tr class="border-b">
              <td class="py-3 font-medium"><%= tt.name %></td>
              <td class="py-3"><%= number_to_currency(tt.price) %></td>
              <td class="py-3"><%= tt.quantity %></td>
              <td class="py-3"><%= tt.available_quantity %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-500">No ticket types defined.</p>
    <% end %>
  </div>

  <!-- Recent Orders -->
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold mb-4">Recent Orders</h2>
    <% if @orders.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-gray-500">
            <th class="pb-2">Reference</th>
            <th class="pb-2">User</th>
            <th class="pb-2">Status</th>
            <th class="pb-2">Total</th>
            <th class="pb-2">Date</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr class="border-b">
              <td class="py-3 font-mono text-xs"><%= order.reference_number %></td>
              <td class="py-3"><%= order.user.name %></td>
              <td class="py-3">
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
                  <%= order.confirmed? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= order.status.capitalize %>
                </span>
              </td>
              <td class="py-3"><%= number_to_currency(order.total_amount) %></td>
              <td class="py-3"><%= order.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-500">No orders yet.</p>
    <% end %>
  </div>
</div>

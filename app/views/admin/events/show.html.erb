<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= @event.name %></h1>
    <div class="flex gap-2">
      <% if @event.draft? %>
        <%= link_to "Publish", publish_admin_event_path(@event), data: { turbo_method: :patch, turbo_confirm: "Publish this event?" }, class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 text-sm" %>
      <% end %>
      <% unless @event.cancelled? %>
        <%= link_to "Cancel Event", cancel_admin_event_path(@event), data: { turbo_method: :patch, turbo_confirm: "Cancel this event?" }, class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 text-sm" %>
      <% end %>
      <%= link_to "Edit", edit_admin_event_path(@event), class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-sm" %>
    </div>
  </div>

  <!-- Event Details -->
  <div class="bg-white rounded-xl shadow p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <dt class="text-sm text-gray-500">Status</dt>
        <dd class="mt-1">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium
            <%= case @event.status
                when 'draft' then 'bg-gray-100 text-gray-800'
                when 'published' then 'bg-green-100 text-green-800'
                when 'cancelled' then 'bg-red-100 text-red-800'
                when 'completed' then 'bg-blue-100 text-blue-800'
                end %>">
            <%= @event.status.capitalize %>
          </span>
        </dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Organizer</dt>
        <dd class="font-medium"><%= @event.organizer.name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Venue</dt>
        <dd class="font-medium"><%= @event.venue.name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Dates</dt>
        <dd class="font-medium"><%= @event.starts_at.strftime("%b %d, %Y %I:%M %p") %> &mdash; <%= @event.ends_at.strftime("%b %d, %Y %I:%M %p") %></dd>
      </div>
      <div class="md:col-span-2">
        <dt class="text-sm text-gray-500">Description</dt>
        <dd class="mt-1 text-gray-700"><%= @event.description %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Waiting Room</dt>
        <dd class="font-medium"><%= @event.waiting_room_enabled? ? "Enabled (capacity: #{@event.waiting_room_capacity})" : "Disabled" %></dd>
      </div>
    </dl>
  </div>

  <!-- Ticket Types -->
  <div class="bg-white rounded-xl shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Ticket Types</h2>
      <% if @event.seated_event? %>
        <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20">
          <%= @event.seating_customer_pick? ? "Customer picks seats" : "Auto-assign seats" %>
        </span>
      <% end %>
    </div>
    <% if @ticket_types.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-gray-500">
            <th class="pb-2">Name</th>
            <% if @sections.present? %>
              <th class="pb-2">Section</th>
            <% end %>
            <th class="pb-2">Price</th>
            <th class="pb-2">Quantity</th>
            <th class="pb-2">Sold</th>
            <th class="pb-2">Available</th>
          </tr>
        </thead>
        <tbody>
          <% @ticket_types.each do |tt| %>
            <tr class="border-b">
              <td class="py-3 font-medium"><%= tt.name %></td>
              <% if @sections.present? %>
                <td class="py-3">
                  <% if tt.section %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset
                      <%= tt.section.general_admission? ? 'bg-blue-50 text-blue-700 ring-blue-600/20' : 'bg-purple-50 text-purple-700 ring-purple-600/20' %>">
                      <%= tt.section.name %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">&mdash;</span>
                  <% end %>
                </td>
              <% end %>
              <td class="py-3"><%= number_to_currency(tt.price) %></td>
              <td class="py-3"><%= tt.quantity %></td>
              <td class="py-3"><%= tt.quantity - tt.available_quantity %></td>
              <td class="py-3"><%= tt.available_quantity %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-500">No ticket types defined.</p>
    <% end %>
  </div>

  <!-- Seating Layout -->
  <% if @sections.present? %>
    <div class="bg-white rounded-xl shadow p-6">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <h2 class="text-lg font-semibold text-gray-900">Seating Layout</h2>
        </div>
        <span class="text-sm text-gray-500"><%= @sections.size %> section(s)</span>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap items-center gap-4 text-sm mb-5">
        <div class="flex items-center gap-1.5">
          <div class="h-5 w-5 rounded bg-emerald-500 ring-1 ring-emerald-600"></div>
          <span class="text-gray-600">Available</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="h-5 w-5 rounded bg-rose-500 ring-1 ring-rose-600"></div>
          <span class="text-gray-600">Sold</span>
        </div>
      </div>

      <div class="space-y-5">
        <% @sections.each do |section| %>
          <div class="rounded-xl border border-gray-200 p-5">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
              <div class="flex items-center gap-3">
                <h3 class="font-semibold text-gray-900"><%= section.name %></h3>
                <% if section.general_admission? %>
                  <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20">GA</span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-600/20">Seated</span>
                <% end %>
              </div>

              <% if section.general_admission? %>
                <% available_ga = section.available_capacity_for_event(@event) %>
                <% sold_ga = section.capacity - available_ga %>
                <div class="text-sm">
                  <span class="font-semibold text-gray-900"><%= sold_ga %></span>
                  <span class="text-gray-500">/ <%= section.capacity %> sold</span>
                </div>
              <% else %>
                <% available_seats = section.available_seats_for_event(@event) %>
                <% total_seats = section.active_seats.count %>
                <% sold_seats = total_seats - available_seats.count %>
                <div class="text-sm">
                  <span class="font-semibold text-gray-900"><%= sold_seats %></span>
                  <span class="text-gray-500">/ <%= total_seats %> sold</span>
                </div>
              <% end %>
            </div>

            <% if section.seated? && section.seats.any? %>
              <% available_seat_ids = section.available_seats_for_event(@event).pluck(:id) %>
              <div class="overflow-x-auto">
                <div class="inline-block rounded-lg bg-gray-50 p-4 min-w-fit">
                  <div class="mb-3 text-center">
                    <div class="inline-block rounded-t-xl bg-gray-300 px-12 py-1.5 text-xs font-semibold uppercase tracking-widest text-gray-600">Stage</div>
                  </div>

                  <% section.rows.each do |row_label, seats| %>
                    <div class="flex items-center gap-1 mb-1">
                      <span class="w-7 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                      <% seats.each do |seat| %>
                        <% available = available_seat_ids.include?(seat.id) %>
                        <div class="h-7 w-7 rounded text-center text-xs leading-7 font-medium
                          <%= available ? 'bg-emerald-500 text-white ring-1 ring-emerald-600' : 'bg-rose-500 text-white ring-1 ring-rose-600' %>"
                             title="<%= available ? 'Available' : 'Sold' %> — Row <%= seat.row_label %>, Seat <%= seat.seat_number %>">
                          <%= seat.seat_number %>
                        </div>
                      <% end %>
                      <span class="w-7 text-center text-xs font-bold text-gray-500 shrink-0"><%= row_label %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% elsif section.general_admission? %>
              <% available_ga = section.available_capacity_for_event(@event) %>
              <% sold_ga = section.capacity - available_ga %>
              <% pct = section.capacity > 0 ? (sold_ga.to_f / section.capacity * 100).round : 0 %>
              <div class="mt-2">
                <div class="h-3 w-full rounded-full bg-gray-200 overflow-hidden">
                  <div class="h-full rounded-full <%= pct >= 90 ? 'bg-red-500' : pct >= 70 ? 'bg-amber-500' : 'bg-green-500' %>" style="width: <%= pct %>%"></div>
                </div>
                <div class="mt-1 flex items-center justify-between text-xs text-gray-500">
                  <span><%= pct %>% sold</span>
                  <span><%= available_ga %> remaining</span>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Recent Orders -->
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold mb-4">Recent Orders</h2>
    <% if @orders.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-gray-500">
            <th class="pb-2">Reference</th>
            <th class="pb-2">User</th>
            <th class="pb-2">Status</th>
            <th class="pb-2">Total</th>
            <th class="pb-2">Date</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr class="border-b">
              <td class="py-3 font-mono text-xs"><%= order.reference_number %></td>
              <td class="py-3"><%= order.user.name %></td>
              <td class="py-3">
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
                  <%= order.confirmed? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= order.status.capitalize %>
                </span>
              </td>
              <td class="py-3"><%= number_to_currency(order.total_amount) %></td>
              <td class="py-3"><%= order.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-500">No orders yet.</p>
    <% end %>
  </div>
</div>

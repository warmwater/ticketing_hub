<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Users</h1>
  </div>

  <!-- Role Filter Tabs -->
  <div class="border-b border-gray-200 mb-6">
    <nav class="-mb-px flex space-x-8">
      <%= link_to "All", admin_users_path, class: "whitespace-nowrap pb-3 px-1 border-b-2 text-sm font-medium #{params[:role].blank? ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
      <%= link_to "Attendants", admin_users_path(role: "attendant"), class: "whitespace-nowrap pb-3 px-1 border-b-2 text-sm font-medium #{params[:role] == 'attendant' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
      <%= link_to "Organizers", admin_users_path(role: "organizer"), class: "whitespace-nowrap pb-3 px-1 border-b-2 text-sm font-medium #{params[:role] == 'organizer' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
      <%= link_to "Admins", admin_users_path(role: "admin"), class: "whitespace-nowrap pb-3 px-1 border-b-2 text-sm font-medium #{params[:role] == 'admin' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" %>
    </nav>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-indigo-600">
                <%= link_to user.name, admin_user_path(user), class: "hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% role_classes = case user.role
                  when "admin" then "bg-red-100 text-red-800"
                  when "organizer" then "bg-blue-100 text-blue-800"
                  when "attendant" then "bg-green-100 text-green-800"
                  else "bg-gray-100 text-gray-800"
                end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= role_classes %>">
                  <%= user.role.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= user.phone %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= user.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                <%= link_to "View", admin_user_path(user), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                <%= link_to "Edit", edit_admin_user_path(user), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-4">
    <%== pagy_nav(@pagy) %>
  </div>
</div>

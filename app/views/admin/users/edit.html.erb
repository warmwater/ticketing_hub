<div class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6">
    <%= link_to ("&larr; " + t("admin.users.edit.back")).html_safe, admin_users_path, class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t("admin.users.edit.title") %></h1>

  <div class="bg-white rounded-lg shadow overflow-hidden max-w-2xl">
    <%= form_with model: @user, url: admin_user_path(@user), class: "p-6 space-y-6" do |f| %>

      <% if @user.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                <%= t("admin.users.edit.errors_title", count: @user.errors.count) %>
              </h3>
              <ul class="mt-2 list-disc list-inside text-sm text-red-700">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div>
        <%= f.label :name, t("admin.users.edit.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :email, t("admin.users.edit.email"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :role, t("admin.users.edit.role"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :role, [[t("roles.attendant"), "attendant"], [t("roles.organizer"), "organizer"], [t("roles.admin"), "admin"]], {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :phone, t("admin.users.edit.phone"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :phone, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-200">
        <%= link_to t("admin.users.edit.cancel"), admin_user_path(@user), class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
        <%= f.submit t("admin.users.edit.update_user"), class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

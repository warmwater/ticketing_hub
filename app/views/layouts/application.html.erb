<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "TicketHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="TicketHub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-full flex-col bg-gray-50 antialiased <%= 'turbo-native' if turbo_native_app? %>">
    <%# Navbar - hidden in Turbo Native since native app handles navigation %>
    <% unless turbo_native_app? %>
      <%= render "shared/navbar" %>
    <% end %>

    <%# Flash messages %>
    <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
      <%= render "shared/flash" %>
    </div>

    <%# Main content %>
    <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8">
      <%= yield %>
    </main>

    <%# Footer - hidden in Turbo Native %>
    <% unless turbo_native_app? %>
      <footer class="mt-auto border-t border-gray-200 bg-white">
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <div class="md:flex md:items-center md:justify-between">
            <div class="flex items-center gap-2 text-indigo-600">
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
              <span class="text-lg font-bold tracking-tight">TicketHub</span>
            </div>
            <div class="mt-4 flex items-center gap-6 md:mt-0">
              <%= link_to "Events", events_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
              <%= link_to "About", "#", class: "text-sm text-gray-500 hover:text-gray-700" %>
              <%= link_to "Contact", "#", class: "text-sm text-gray-500 hover:text-gray-700" %>
              <%= link_to "Privacy", "#", class: "text-sm text-gray-500 hover:text-gray-700" %>
              <%= link_to "Terms", "#", class: "text-sm text-gray-500 hover:text-gray-700" %>
            </div>
          </div>
          <div class="mt-6 border-t border-gray-100 pt-6">
            <p class="text-center text-xs text-gray-400">
              &copy; <%= Date.current.year %> TicketHub. All rights reserved.
            </p>
          </div>
        </div>
      </footer>
    <% end %>
  </body>
</html>

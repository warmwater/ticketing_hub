<!DOCTYPE html>
<html class="h-full bg-gray-100" lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Organizer - TicketHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="TicketHub Organizer">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full antialiased <%= 'turbo-native' if turbo_native_app? %>">
    <div class="min-h-full" data-controller="sidebar">
      <%# Mobile sidebar overlay %>
      <div class="relative z-40 lg:hidden hidden"
           data-sidebar-target="overlay"
           role="dialog"
           aria-modal="true">
        <%# Backdrop %>
        <div class="fixed inset-0 bg-gray-900/80 transition-opacity duration-300 ease-in-out opacity-0"
             data-action="click->sidebar#close"
             data-sidebar-target="backdrop"></div>

        <%# Mobile sidebar panel %>
        <div class="fixed inset-0 flex">
          <div class="relative mr-16 flex w-full max-w-xs flex-1 -translate-x-full transition-transform duration-300 ease-in-out"
               data-sidebar-target="panel">
            <%# Close button %>
            <div class="absolute left-full top-0 flex w-16 justify-center pt-5">
              <button type="button"
                      class="-m-2.5 p-2.5 text-white"
                      data-action="click->sidebar#close">
                <span class="sr-only"><%= t("organizer_layout.sidebar.close_sidebar") %></span>
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <%# Mobile sidebar content %>
            <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-purple-950 px-6 pb-4">
              <div class="flex h-16 shrink-0 items-center">
                <%= link_to organizer_root_path, class: "flex items-center gap-2 text-white" do %>
                  <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                  </svg>
                  <span class="text-lg font-bold">TicketHub</span>
                  <span class="rounded-md bg-purple-700 px-1.5 py-0.5 text-xs font-medium text-purple-200">Organizer</span>
                <% end %>
              </div>

              <nav class="flex flex-1 flex-col">
                <ul role="list" class="flex flex-1 flex-col gap-y-1">
                  <li>
                    <%= link_to organizer_root_path,
                        class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == organizer_root_path ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                      <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                      </svg>
                      <%= t("organizer_layout.sidebar.dashboard") %>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to organizer_events_path,
                        class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/organizer/events') ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                      <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                      </svg>
                      <%= t("organizer_layout.sidebar.my_events") %>
                    <% end %>
                  </li>
                  <li>
                    <%= link_to organizer_orders_path,
                        class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/organizer/orders') ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                      <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
                      </svg>
                      <%= t("organizer_layout.sidebar.orders") %>
                    <% end %>
                  </li>
                  <li class="mt-auto">
                    <%= link_to root_path,
                        class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium text-purple-200 hover:bg-purple-800 hover:text-white" do %>
                      <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                      </svg>
                      <%= t("organizer_layout.sidebar.back_to_site") %>
                    <% end %>
                  </li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <%# Desktop sidebar %>
      <div class="hidden lg:fixed lg:inset-y-0 lg:z-40 lg:flex lg:w-64 lg:flex-col">
        <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-purple-950 px-6 pb-4">
          <div class="flex h-16 shrink-0 items-center">
            <%= link_to organizer_root_path, class: "flex items-center gap-2 text-white" do %>
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
              <span class="text-lg font-bold">TicketHub</span>
              <span class="rounded-md bg-purple-700 px-1.5 py-0.5 text-xs font-medium text-purple-200">Organizer</span>
            <% end %>
          </div>

          <nav class="flex flex-1 flex-col">
            <ul role="list" class="flex flex-1 flex-col gap-y-1">
              <li>
                <%= link_to organizer_root_path,
                    class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == organizer_root_path ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                  <%= t("organizer_layout.sidebar.dashboard") %>
                <% end %>
              </li>
              <li>
                <%= link_to organizer_events_path,
                    class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/organizer/events') ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                  </svg>
                  <%= t("organizer_layout.sidebar.my_events") %>
                <% end %>
              </li>
              <li>
                <%= link_to organizer_orders_path,
                    class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/organizer/orders') ? 'bg-purple-800 text-white' : 'text-purple-200 hover:bg-purple-800 hover:text-white'}" do %>
                  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
                  </svg>
                  <%= t("organizer_layout.sidebar.orders") %>
                <% end %>
              </li>
              <li class="mt-auto">
                <%= link_to root_path,
                    class: "group flex gap-x-3 rounded-md px-3 py-2 text-sm font-medium text-purple-200 hover:bg-purple-800 hover:text-white" do %>
                  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                  </svg>
                  <%= t("organizer_layout.sidebar.back_to_site") %>
                <% end %>
              </li>
            </ul>
          </nav>
        </div>
      </div>

      <%# Main content area %>
      <div class="lg:pl-64">
        <%# Top bar %>
        <div class="sticky top-0 z-30 flex h-16 shrink-0 items-center gap-x-4 border-b border-gray-200 bg-white px-4 shadow-sm sm:gap-x-6 sm:px-6 lg:px-8">
          <%# Mobile sidebar toggle %>
          <button type="button"
                  class="-m-2.5 p-2.5 text-gray-700 lg:hidden"
                  data-action="click->sidebar#open">
            <span class="sr-only"><%= t("organizer_layout.sidebar.open_sidebar") %></span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>

          <%# Separator %>
          <div class="h-6 w-px bg-gray-300 lg:hidden" aria-hidden="true"></div>

          <div class="flex flex-1 items-center justify-between">
            <h1 class="text-lg font-semibold text-gray-900">
              <%= content_for(:page_title) || t("organizer_layout.sidebar.page_title_default") %>
            </h1>

            <%# User info and sign out %>
            <div class="flex items-center gap-x-4">
              <div class="hidden sm:flex sm:items-center sm:gap-x-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-purple-600 text-sm font-semibold text-white">
                  <%= current_user.name.first.upcase %>
                </div>
                <span class="text-sm font-medium text-gray-700"><%= current_user.name %></span>
              </div>
              <%= button_to t("organizer_layout.sidebar.sign_out"), destroy_user_session_path,
                  method: :delete,
                  class: "rounded-md bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
            </div>
          </div>
        </div>

        <%# Page content %>
        <main class="py-6">
          <div class="px-4 sm:px-6 lg:px-8">
            <%# Flash messages %>
            <%= render "shared/flash" %>

            <%= yield %>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
